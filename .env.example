SEPOLIA_RPC_URL=https://11155111.rpc.thirdweb.com
DEPLOYER_PRIVATE_KEY=0xPUT_YOUR_TESTNET_PRIVATE_KEY_HERE
SABLIER_LOCKUP_SEPOLIA=0xC2Da366fD67423b500cDF4712BdB41d0995b0794

# agent/ (keeper) — see agent/README.md
# NOMOS_PAYROLL_ADDRESS and NOMOS_TOKEN_ADDRESS come from a deploy script's
# output (deployments/sepolia.json). AGENT_PRIVATE_KEY can reuse
# DEPLOYER_PRIVATE_KEY above — owner and agent are the same key in this
# hackathon setup (see NomosPayroll's constructor / README's future-work note).
NOMOS_PAYROLL_ADDRESS=0xPUT_DEPLOYED_NOMOSPAYROLL_ADDRESS_HERE
NOMOS_TOKEN_ADDRESS=0xPUT_DEPLOYED_NOMOSTOKEN_ADDRESS_HERE
AGENT_PRIVATE_KEY=0xPUT_AGENT_TESTNET_PRIVATE_KEY_HERE
CHECK_INTERVAL_SECONDS=15
COOLDOWN_BUFFER_SECONDS=5