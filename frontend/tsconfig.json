{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src",
    "../agent/src/contracts.ts",
    "../agent/src/nox.ts",
    "../agent/src/events.ts",
    "../artifacts/contracts/NomosPayroll.sol/NomosPayroll.json",
    "../artifacts/contracts/NomosToken.sol/NomosToken.json"
  ]
}
